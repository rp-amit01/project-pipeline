pipeline {
    agent any

    stages {
        
        stage('pull-job') {
            steps {
                git branch: 'main', url: 'https://github.com/SanjayTomar22/EasyCRUD.git'
                echo 'Pull Job Success !'
            }
        }
        
        stage('build-job') {
            steps {
                echo 'Build Job Success !'
            }
        }
        
        stage('test-job') {
            steps {
                echo 'Test Job Success !'
            }
        }
        
        stage('deploy-job') {
            steps {
                echo 'Deploy Job Success !'
            }
        }
    }
}
