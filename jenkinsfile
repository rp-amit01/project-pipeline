pipeline {
    agent any

    stages {
        
        stage('pull-job') {
            steps {
                git branch: 'main', url: 'https://github.com/SanjayTomar22/EasyCRUD.git'
                echo 'Pull Job Success !'
            }
        }

        stage('deploy-job') {
            steps {
                //echo 'Build Job Success !'
            }
        }
        
        stage('build-job') {
            steps {
                sh '''cd backend 
                mvn clean package -DskipTests
                '''
                echo 'Build Job Success !'
            }
        }
        
        stage('test-job') {
            steps {
                sh ''' cd backend 
                      mvn clean verify sonar:sonar \\
                      -Dsonar.projectKey=pipeline \\
                      -Dsonar.projectName=\'pipeline\' \\
                      -Dsonar.host.url=http://3.107.158.32:9000 \\
                      -Dsonar.token=sqp_829a40ae3ec9e7c6d6a0321085c84191b81c3029
                    '''
                echo 'Test Job Success !'
            }
        }
        
        stage('deploy-job') {
            steps {
                echo 'Deploy Job Success !'
            }
        }
    }
}
